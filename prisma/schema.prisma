generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

model professor {
  id Int @id @default(autoincrement())
  nomeProf String
  emailProf String @unique
  matriculaProf String @unique

  alocacoes Alocacao[]
}

model Disciplina {
  idDisciplina Int @id @default(autoincrement())
  matriculaDisciplina String @unique
  nomeDisciplina String @unique

  alocacoes Alocacao[]
}

model Sala {
  idSala        Int     @id @default(autoincrement())
  nomeSala      String  @unique 
  tipoSala      String                 

  alocacoes    Alocacao[]
  solicitacoes Solicitacao[]
}

model Curso {
  idCurso    Int     @id @default(autoincrement())
  nomeCurso  String  
  siglaCurso String?
  corCurso   String

  alocacoes Alocacao[]
}

model Administrador {
  idAdm     Int    @id @default(autoincrement())
  nomeAdm   String
  emailAdm  String @unique
  senhaAdm  String 
}

model Periodo {
  idPeriodo   Int      @id @default(autoincrement())
  semestre    String   
  descricao   String   
  dataInicio  DateTime 
  dataFim     DateTime 

  alocacoes Alocacao[]
}

model Alocacao {
  idAlocacao    Int      @id @default(autoincrement())
  
  diaSemana     String  
  horarioInicio String  
  horarioFim    String  
  dataInicio    DateTime @default(now()) 
  dataFim       DateTime @default(now())

  professorId   Int
  professor     professor  @relation(fields: [professorId], references: [id])  

  disciplinaId  Int
  disciplina    Disciplina @relation(fields: [disciplinaId], references: [idDisciplina])

  salaId        Int
  sala          Sala       @relation(fields: [salaId], references: [idSala])

  cursoId       Int
  curso         Curso      @relation(fields: [cursoId], references: [idCurso])

  periodoId     Int
  periodo       Periodo    @relation(fields: [periodoId], references: [idPeriodo])
}

model Solicitacao {
  idSolicitacao Int      @id @default(autoincrement())

  // Dados do solicitante
  solicitante   String
  email         String
  matricula     String
  papel         String   // 'aluno' | 'professor'

  // Dados do evento
  motivo        String
  descricao     String
  observacoes   String?
  participantes Int?

  // Dados do agendamento
  diaSemana     String
  dataEvento    String?
  horarioInicio String
  horarioFim    String

  // Status e metadados
  status        String   @default("pendente") // 'pendente' | 'aprovado' | 'recusado'
  motivoRecusa  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relação com sala
  salaId        Int
  sala          Sala     @relation(fields: [salaId], references: [idSala])
}

model Usuario {
  idUsuario    Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  username     String   @unique
  senhaHash    String
  papel        String   // aluno | professor | admin
  status       String   @default("pendente") // pendente | aprovado | recusado

  // aluno
  matricula    String?
  curso        String?

  // professor
  siape        String?
  departamento String?

  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}